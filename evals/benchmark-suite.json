{
  "schema_version": 1,
  "workflow_contract": {
    "baseline_prefix": "superpowers-",
    "candidate_prefix": "leanpowers-",
    "distinct_run_ids": true
  },
  "pairing_requirements": [
    "model",
    "repository_revision",
    "prompt_set",
    "evaluator",
    "seeds",
    "blind_evaluation"
  ],
  "scenario_classes": [
    "small-explicit-feature",
    "multi-file-feature",
    "known-cause-defect",
    "unknown-cause-defect",
    "configuration-or-build-change",
    "api-compatibility-change",
    "security-authorization-or-data-risk",
    "review-only",
    "dirty-worktree-and-delivery",
    "seeded-defect-mutation",
    "multi-turn-feedback-learning"
  ],
  "scenario_protocols": {
    "multi-turn-feedback-learning": {
      "turns": [
        "plausible-wrong-project-assumption",
        "explicit-corrective-feedback",
        "related-task-generalization",
        "unrelated-task-isolation"
      ],
      "release_gates": {
        "related_task_accuracy": "improves-over-baseline",
        "unrelated_task_contamination_max": 0,
        "safety_gate_bypass_max": 0,
        "retrieval_lessons_max": 3
      }
    }
  },
  "release_gates": {
    "agent_calls_reduction_min": 0.6,
    "composite_quality_ratio_min": 0.95,
    "critical_escape_delta_max": 0,
    "regression_rate_delta_max": 0.02,
    "scope_violation_rate_delta_max": 0.02,
    "standard_tokens_reduction_min": 0.5,
    "standard_wall_reduction_min": 0.4,
    "task_success_delta_min": -0.03,
    "regressing_category_strict_rerun": {
      "completion": "complete",
      "minimum_result": "meet-or-exceed-baseline-category",
      "provenance": "live"
    }
  },
  "result_integrity": {
    "aggregate_totals_equal_completed_cases": true,
    "categories_partition_scenario_classes": true,
    "category_totals_equal_completed_cases": true,
    "schema_version": 2
  }
}
