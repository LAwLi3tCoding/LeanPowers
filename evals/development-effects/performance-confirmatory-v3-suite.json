    {
      "id": "generation-guarded-refresh-cache",
      "scenario_class": "unknown-cause-defect",
      "reporting_category": "generation-guarded cache debug",
      "risk_level": "strict",
      "expected_workflow": "debug",
      "workspace": "cases/generation-guarded-refresh-cache/workspace",
      "verifier_files": [
        "cases/generation-guarded-refresh-cache/verifier/refresh-cache.hidden.mjs"
      ],
      "task": "Users report that concurrent, overlapping same-key generations can settle out of order, and an older in-flight refresh settling late can discard a newer cached generation. Before editing, run the included node repro/generation-guarded-refresh-cache.mjs and use its structured output to identify the first incorrect transition. Fix createRefreshCache(loadValue) so get(key) coalesces and returns the exact current same-key promise, refresh(key) always starts and installs a newer same-key generation, and generations remain isolated per key. A stale success must still fulfill its own waiter but must never overwrite a newer current generation. A stale rejection must propagate the same error to its own waiter but must never clear a newer current generation. A rejection from the current generation removes only that entry so a later same-key get retries without evicting other keys. invalidate(key) must advance only that key's generation, delete its current entry, return whether an entry existed, and prevent any invalidated in-flight settlement from repopulating the cache. Keep different keys' loads, refreshes, failures, and invalidations independent. Validate loadValue as a function and every method key as a non-empty primitive string. Preserve the exact get/refresh/invalidate method surface and the exact direct and public named export surfaces, with createRefreshCache remaining a direct named export. Add focused regressions that independently prove stale-success and stale-rejection guards, same-key in-flight coalescing, newer-success visibility while an older load remains pending, per-key isolation, invalidation against stale repopulation, current-rejection retry, validation, API compatibility, and operation without timers or network access. Run the full test suite and rerun the same included repro, whose first nonblank JSON object must match the resolved behavior. Do not commit, install packages, use the network, or create another worktree.",
      "reproduction_contract": {
        "command": "node repro/generation-guarded-refresh-cache.mjs",
        "expected_output": {
          "scenario": "generation-guarded-refresh-cache",
          "observations": [
            { "action": "get", "generation": 1 },
            { "action": "refresh", "generation": 2 },
            {
              "action": "resolve",
              "generation": 2,
              "value": { "id": "profile-7", "version": 2 }
            },
            {
              "action": "reject",
              "generation": 1,
              "reason": "older generation failed late"
            },
            {
              "action": "get-after-stale-rejection",
              "expected_version": 2,
              "observed_version": 3,
              "loader_calls": 3
            }
          ],
          "first_incorrect_transition": {
            "stage": "stale-rejection-settlement",
            "expected": "generation 2 remains cached",
            "stale_rejection_cleared_newer_generation": true
          },
          "resolution": null
        },
