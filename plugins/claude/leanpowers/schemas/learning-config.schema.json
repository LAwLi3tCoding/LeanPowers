{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://leanpowers.dev/schemas/learning-config.schema.json",
  "title": "LeanPowers learning configuration",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "enabled",
    "project_id",
    "enabled_at"
  ],
  "properties": {
    "schema_version": {
      "const": 1
    },
    "enabled": {
      "type": "boolean"
    },
    "project_id": {
      "type": "string",
      "pattern": "^sha256:[a-f0-9]{64}$"
    },
    "enabled_at": {
      "type": "string",
      "format": "date-time"
    }
  }
}
