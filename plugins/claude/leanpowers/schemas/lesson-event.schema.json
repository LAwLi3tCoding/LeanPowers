{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://leanpowers.dev/schemas/lesson-event.schema.json",
  "title": "LeanPowers lesson event",
  "oneOf": [
    {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "event_id",
        "project_id",
        "recorded_at",
        "action",
        "lesson_id",
        "kind",
        "scope",
        "rule",
        "evidence",
        "confidence",
        "supersedes",
        "expires_at"
      ],
      "properties": {
        "schema_version": { "const": 1 },
        "event_id": { "type": "string", "format": "uuid", "pattern": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-4[0-9a-fA-F]{3}-[89aAbB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$" },
        "project_id": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
        "recorded_at": { "type": "string", "format": "date-time" },
        "action": { "const": "activate" },
        "lesson_id": { "type": "string", "minLength": 1, "maxLength": 128, "pattern": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-4[0-9a-fA-F]{3}-[89aAbB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$" },
        "kind": {
          "type": "string",
          "enum": ["preference", "correction", "outcome", "confirmation"]
        },
        "scope": {
          "type": "object",
          "additionalProperties": false,
          "required": ["workflows", "path_prefixes", "tags"],
          "properties": {
            "workflows": {
              "type": "array",
              "maxItems": 32,
              "uniqueItems": true,
              "items": { "type": "string", "minLength": 1, "maxLength": 64 }
            },
            "path_prefixes": {
              "type": "array",
              "maxItems": 32,
              "uniqueItems": true,
              "items": {
                "type": "string",
                "minLength": 1,
                "maxLength": 500,
                "pattern": "^(?![/\\\\])(?![A-Za-z]:[/\\\\])(?!.*(?:^|[/\\\\])\\.\\.(?:[/\\\\]|$)).+$"
              }
            },
            "tags": {
              "type": "array",
              "maxItems": 32,
              "uniqueItems": true,
              "items": { "type": "string", "minLength": 1, "maxLength": 20 }
            }
          }
        },
        "rule": { "type": "string", "minLength": 1, "maxLength": 500 },
        "evidence": {
          "type": "object",
          "additionalProperties": false,
          "required": ["source", "summary", "revision"],
          "properties": {
            "source": { "type": "string", "minLength": 1, "maxLength": 64 },
            "summary": { "type": "string", "minLength": 1, "maxLength": 500 },
            "revision": {
              "anyOf": [
                { "type": "string", "minLength": 1, "maxLength": 256 },
                { "type": "null" }
              ]
            }
          }
        },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
        "supersedes": {
          "type": "array",
          "maxItems": 32,
          "uniqueItems": true,
          "items": { "type": "string", "minLength": 1, "maxLength": 128, "pattern": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-4[0-9a-fA-F]{3}-[89aAbB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$" }
        },
        "expires_at": {
          "anyOf": [
            { "type": "string", "format": "date-time" },
            { "type": "null" }
          ]
        }
      }
    },
    {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "event_id",
        "project_id",
        "recorded_at",
        "action",
        "lesson_id",
        "evidence",
        "confidence"
      ],
      "properties": {
        "schema_version": { "const": 1 },
        "event_id": { "type": "string", "format": "uuid", "pattern": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-4[0-9a-fA-F]{3}-[89aAbB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$" },
        "project_id": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
        "recorded_at": { "type": "string", "format": "date-time" },
        "action": { "const": "reinforce" },
        "lesson_id": { "type": "string", "minLength": 1, "maxLength": 128, "pattern": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-4[0-9a-fA-F]{3}-[89aAbB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$" },
        "evidence": {
          "type": "object",
          "additionalProperties": false,
          "required": ["source", "summary", "revision"],
          "properties": {
            "source": { "type": "string", "minLength": 1, "maxLength": 64 },
            "summary": { "type": "string", "minLength": 1, "maxLength": 500 },
            "revision": {
              "anyOf": [
                { "type": "string", "minLength": 1, "maxLength": 256 },
                { "type": "null" }
              ]
            }
          }
        },
        "confidence": { "type": "number", "minimum": 0, "maximum": 1 }
      }
    },
    {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "schema_version",
        "event_id",
        "project_id",
        "recorded_at",
        "action",
        "lesson_id",
        "kind",
        "scope",
        "rule",
        "evidence",
        "confidence",
        "supersedes",
        "expires_at"
      ],
      "properties": {
        "schema_version": { "const": 1 },
        "event_id": { "type": "string", "format": "uuid", "pattern": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-4[0-9a-fA-F]{3}-[89aAbB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$" },
        "project_id": { "type": "string", "pattern": "^sha256:[a-f0-9]{64}$" },
        "recorded_at": { "type": "string", "format": "date-time" },
        "action": { "const": "supersede" },
        "lesson_id": { "type": "string", "minLength": 1, "maxLength": 128, "pattern": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-4[0-9a-fA-F]{3}-[89aAbB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$" },
        "kind": {
          "type": "string",
          "enum": ["preference", "correction", "outcome", "confirmation"]
        },
        "scope": {
          "type": "object",
          "additionalProperties": false,
          "required": ["workflows", "path_prefixes", "tags"],
          "properties": {
            "workflows": {
              "type": "array",
              "maxItems": 32,
