{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/LAwLi3tCoding/LeanPowers/schemas/evidence.schema.json",
  "title": "LeanPowers evidence entry",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "revision_fingerprint",
    "command",
    "scope",
    "result",
    "exit_code",
    "timestamp",
    "summary",
    "provenance"
  ],
  "properties": {
    "revision_fingerprint": { "type": "string", "minLength": 1 },
    "command": { "type": "string", "minLength": 1 },
    "scope": { "type": "string", "minLength": 1 },
    "result": { "enum": ["pass", "fail", "unavailable"] },
    "exit_code": { "type": ["integer", "null"] },
    "timestamp": { "type": "string", "format": "date-time" },
    "summary": { "type": "string", "minLength": 1, "maxLength": 1000 },
    "provenance": { "enum": ["live", "simulated"] }
  }
}
